@startuml
title OEM - Generic Sequence Diagram for EDIT/UPDATE Operation

participant ":API Client" as Client
participant ":XRoutes" as Routes
participant ":authenticate" as AuthMW
participant ":XController" as Controller
participant ":XService" as Service
database "MongoDB" as MongoDB

Client -> Routes : PUT /api/xs/{id} (updateXDto)
activate Routes

Routes -> AuthMW : authenticate(req, res, next)
activate AuthMW

AuthMW -> AuthMW : verifyIdToken(token)
AuthMW -> AuthMW : getUserRole() from MasterData
AuthMW -> AuthMW : req.user = AuthenticatedUser
AuthMW -->> Routes : next()
deactivate AuthMW

Routes -> Controller : update(req, res)
activate Controller

Controller -> Controller : Extract id from req.params
Controller -> Controller : Extract & validate DTO from req.body
Controller -> Service : update(id, dto, updatedBy)
activate Service

Service -> MongoDB : X.findByIdAndUpdate(id, dto)
activate MongoDB
MongoDB -->> Service : updatedDocument
deactivate MongoDB

alt Document Found
    Service -->> Controller : xDocument
    Controller -->> Client : 200 OK (xDto)
else Document Not Found
    Service -->> Controller : null
    Controller -->> Client : 404 Not Found
end

deactivate Service
deactivate Controller
deactivate Routes

@enduml
